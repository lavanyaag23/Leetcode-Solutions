/*
 * LeetCode Problem #205 - Isomorphic Strings
 *
 * Difficulty: Easy
 * Topic: Strings
 *
 * Problem Link:
 * https://leetcode.com/problems/isomorphic-strings/
 *
 * Approach:
 * Use two HashMaps to maintain character mappings
 * between both strings. Each character from one
 * string should map uniquely to a character in
 * the other string.
 *
 * Time Complexity: O(n)
 * Space Complexity: O(1)
 */

import java.util.HashMap;

class Solution {
    public boolean isIsomorphic(String s, String t) {

        HashMap<Character, Character> mapST = new HashMap<>();
        HashMap<Character, Character> mapTS = new HashMap<>();

        for (int i = 0; i < s.length(); i++) {

            char c1 = s.charAt(i);
            char c2 = t.charAt(i);

            if (mapST.containsKey(c1) && mapST.get(c1) != c2) {
                return false;
            }

            if (mapTS.containsKey(c2) && mapTS.get(c2) != c1) {
                return false;
            }

            mapST.put(c1, c2);
            mapTS.put(c2, c1);
        }

        return true;
    }
}
