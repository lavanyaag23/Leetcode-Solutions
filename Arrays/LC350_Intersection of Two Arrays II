/*
 * LeetCode Problem #350 - Intersection of Two Arrays II
 *
 * Difficulty: Easy
 * Topic: Arrays, Hash Table, Two Pointers
 *
 * Problem Link:
 * https://leetcode.com/problems/intersection-of-two-arrays-ii/
 *
 * Approach:
 * Store the frequency of elements from the first array
 * using a HashMap. Traverse the second array and add
 * common elements while updating frequencies.
 *
 * Time Complexity: O(n + m)
 * Space Complexity: O(n)
 */

class Solution {
    public int[] intersect(int[] nums1, int[] nums2) {
        HashMap<Integer, Integer> map = new HashMap<>();
        ArrayList<Integer> result = new ArrayList<>();

        for (int num : nums1) {
            map.put(num, map.getOrDefault(num, 0) + 1);
        }

        for (int num : nums2) {
            if (map.containsKey(num) && map.get(num) > 0) {
                result.add(num);
                map.put(num, map.get(num) - 1);
            }
        }

        int[] ans = new int[result.size()];
        for (int i = 0; i < result.size(); i++) {
            ans[i] = result.get(i);
        }

        return ans;
    }
}
